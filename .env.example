# Copy to .env (gitignored) and fill in. All vars are prefixed TEG_.
# Only deployment-specific values + secrets live here. Everything else (model, index,
# dimensions, api versions, paths, knobs) has a default in teg.config.settings.Settings
# and can be overridden with its TEG_<NAME> env var if needed.

# Jira
TEG_JIRA_BASE_URL=
TEG_JIRA_TOKEN=

# Azure AD service principal (auth for both Search and Cosmos; preferred over keys).
# These org-standard names are read directly (aliased); the TEG_AZURE_* names also work.
AZURE_TENANT_ID_DEV=
AZURE_CLIENT_ID_DEV=
AZURE_CLIENT_SECRET_DEV=

# Azure AI Search
TEG_SEARCH_ENDPOINT=
TEG_SEARCH_API_KEY=        # only if NOT using the service principal above

# Cosmos (one container, partition key /sourceId; the service principal above needs the
# "Cosmos DB Built-in Data Contributor" data role on the account).
AZURE_COSMOS_DB_URL=                       # https://<account>.documents.azure.com:443/
AZURE_COSMOS_DB_NAME=idpdb
AZURE_COSMOS_CONTAINER_NAME=theme-and-epic
# TEG_COSMOS_KEY=          # alternative to the service principal (account key)

# LLM (IDP OpenAI-compatible gateway)
TEG_LLM_BASE_URL=
TEG_LLM_APP_ID=

# IDP auth (token endpoint)
TEG_IDP_AUTH_URL=
TEG_IDP_CLIENT_ID=
TEG_IDP_CLIENT_SECRET=
TEG_IDP_USER=
TEG_IDP_PASSWORD=
