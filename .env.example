# Copy to .env and fill in. All vars are prefixed TEG_.

# Jira
TEG_JIRA_BASE_URL=
TEG_JIRA_TOKEN=

# Azure AI Search (unified index)
TEG_SEARCH_ENDPOINT=
TEG_SEARCH_API_KEY=
TEG_SEARCH_INDEX=idp_idmt_data

# Cosmos
TEG_COSMOS_ENDPOINT=
TEG_COSMOS_KEY=
TEG_COSMOS_DATABASE=

# LLM
TEG_LLM_MODEL=
TEG_LLM_API_KEY=
TEG_LLM_REASONING_EFFORT=low
