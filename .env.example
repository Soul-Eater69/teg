# Copy to .env and fill in. All vars are prefixed TEG_.

# Jira
TEG_JIRA_BASE_URL=
TEG_JIRA_TOKEN=

# Azure AI Search (unified index)
TEG_SEARCH_ENDPOINT=
TEG_SEARCH_API_KEY=
TEG_SEARCH_INDEX=idp_idmt_data

# Cosmos
TEG_COSMOS_ENDPOINT=
TEG_COSMOS_KEY=
TEG_COSMOS_DATABASE=

# LLM (IDP OpenAI-compatible gateway)
TEG_LLM_BASE_URL=
TEG_LLM_COMPLETION_PATH=/chat/completions
TEG_LLM_MODEL=gpt-5-mini-idp
TEG_LLM_APP_ID=
TEG_LLM_API_VERSION=2024-04-01-preview
TEG_LLM_REASONING_EFFORT=low
TEG_LLM_TIMEOUT_SECONDS=60
TEG_LLM_VERIFY_SSL=false

# IDP auth (token endpoint)
TEG_IDP_AUTH_URL=
TEG_IDP_CLIENT_ID=
TEG_IDP_CLIENT_SECRET=
TEG_IDP_USER=
TEG_IDP_PASSWORD=
