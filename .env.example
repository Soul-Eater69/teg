# Copy to .env and fill in. All vars are prefixed TEG_.

# Jira
TEG_JIRA_BASE_URL=
TEG_JIRA_TOKEN=
TEG_JIRA_API_VERSION=2
TEG_JIRA_VERIFY_SSL=false
TEG_JIRA_TIMEOUT_SECONDS=30

# Azure AI Search (unified index)
TEG_SEARCH_ENDPOINT=
TEG_SEARCH_API_KEY=
TEG_SEARCH_INDEX=idp_idmt_data

# Cosmos
TEG_COSMOS_ENDPOINT=
TEG_COSMOS_KEY=
TEG_COSMOS_DATABASE=

# LLM (IDP OpenAI-compatible gateway)
TEG_LLM_BASE_URL=
TEG_LLM_COMPLETION_PATH=/api/v1/chatcompletions
TEG_LLM_MODEL=gpt-5-mini-idp
TEG_LLM_APP_ID=
TEG_LLM_API_VERSION=2024-04-01-preview
TEG_LLM_REASONING_EFFORT=low
TEG_LLM_MAX_OUTPUT_TOKENS=
TEG_LLM_TIMEOUT_SECONDS=60
TEG_LLM_VERIFY_SSL=false

# Condense
TEG_CONDENSE_DOC_CHAR_BUDGET=20000
TEG_CONDENSE_MAX_ATTACHMENTS=4

# IDP auth (token endpoint)
TEG_IDP_AUTH_URL=
TEG_IDP_CLIENT_ID=
TEG_IDP_CLIENT_SECRET=
TEG_IDP_USER=
TEG_IDP_PASSWORD=
