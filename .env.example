# Copy to .env and fill in. All vars are prefixed TEG_.

# Jira
TEG_JIRA_BASE_URL=
TEG_JIRA_TOKEN=
TEG_JIRA_API_VERSION=2
TEG_JIRA_VERIFY_SSL=false
TEG_JIRA_TIMEOUT_SECONDS=30

# Azure AI Search (two indices for now)
TEG_SEARCH_ENDPOINT=
TEG_SEARCH_API_KEY=
TEG_SEARCH_INDEX_VALUE_STREAM=idp_kg_data_test
TEG_SEARCH_INDEX_HISTORICAL=idp_idmt_data
TEG_SEARCH_VECTOR_FIELD=content_vector
TEG_SEARCH_SEMANTIC_CONFIG=default

# Value Stream retrieval / review-window tuning
TEG_VS_SEMANTIC_FETCH_K=50
TEG_VS_HISTORICAL_FETCH_K=6
TEG_VS_LLM_CANDIDATE_WINDOW=18
TEG_VS_WINDOW_HEADROOM=8
TEG_VS_MAX_SUPPORTING_TICKETS=2

# Cosmos
TEG_COSMOS_ENDPOINT=
TEG_COSMOS_KEY=
TEG_COSMOS_DATABASE=

# LLM (IDP OpenAI-compatible gateway)
TEG_LLM_BASE_URL=
TEG_LLM_COMPLETION_PATH=/api/v1/chatcompletions
TEG_LLM_MODEL=gpt-5-mini-idp
TEG_LLM_APP_ID=
TEG_LLM_API_VERSION=2024-04-01-preview
TEG_LLM_REASONING_EFFORT=low
TEG_LLM_MAX_OUTPUT_TOKENS=
TEG_LLM_TIMEOUT_SECONDS=60
TEG_LLM_VERIFY_SSL=false

# Condense (fallback path only; idea card is always used in full)
TEG_CONDENSE_DOC_CHAR_BUDGET=20000
TEG_CONDENSE_MAX_ATTACHMENTS=4
TEG_CONDENSE_MAX_ATTACHMENT_BYTES=10000000
TEG_CONDENSE_MIN_DOC_CHARS=200

# IDP auth (token endpoint)
TEG_IDP_AUTH_URL=
TEG_IDP_CLIENT_ID=
TEG_IDP_CLIENT_SECRET=
TEG_IDP_USER=
TEG_IDP_PASSWORD=

# Embeddings (same IDP gateway + auth as the LLM)
TEG_EMBEDDING_MODEL=text-embedding-3-large
TEG_EMBEDDING_DIMENSIONS=3072
TEG_EMBEDDING_PATH=/api/v1/embeddings
TEG_EMBEDDING_API_VERSION=2024-06-01
