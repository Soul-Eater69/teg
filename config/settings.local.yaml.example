# Environment-specific NON-secret config. Copy to settings.local.yaml (gitignored)
# and fill in. These are not secrets (so they don't belong in .env) but they vary per
# deployment and are not committed. Secrets -> .env.

# Jira
jira_base_url: ""

# Azure AI Search
search_endpoint: ""

# Cosmos
cosmos_endpoint: ""
cosmos_database: ""

# LLM (IDP gateway)
llm_base_url: ""
llm_app_id: ""

# IDP auth
idp_auth_url: ""
idp_client_id: ""
idp_user: ""

# Azure AD (service principal; secret -> .env)
azure_tenant_id: ""
azure_client_id: ""
